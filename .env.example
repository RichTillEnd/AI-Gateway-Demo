# ── Required ─────────────────────────────────────────────────────────────────
OPENAI_KEY=sk-your-openai-key-here
JWT_SECRET_KEY=change-this-to-any-random-32-char-string-here

# ── Optional: Alternative AI Model ───────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Optional: Web Search ──────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-your-tavily-key

# ── Optional: Google Image Generation (Imagen) ───────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# ── Optional: Email (for password reset only) ─────────────────────────────────
# Without these, email features are silently disabled.
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=your-gmail@gmail.com

# ── Database (default: SQLite, no setup needed) ───────────────────────────────
# Uncomment to use PostgreSQL instead:
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_gateway_demo

# ── Redis (optional, falls back gracefully if not set) ────────────────────────
# REDIS_URL=redis://localhost:6379

# ── AI Model Overrides (optional) ────────────────────────────────────────────
# OPENAI_MODEL=gpt-4.1
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_IMAGE_MODEL=gpt-image-1
